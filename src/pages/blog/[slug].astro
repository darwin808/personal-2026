---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const slug = post.id.replace(/\.md$/, '');
const pageTitle = `${post.data.title} | Darwin Apolinario`;
const pageDescription = post.data.description;
const canonicalURL = `https://darwinapolinario.xyz/blog/${slug}`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "dateModified": post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Darwin Apolinario",
    "url": "https://darwinapolinario.xyz"
  },
  "publisher": {
    "@type": "Person",
    "name": "Darwin Apolinario",
    "url": "https://darwinapolinario.xyz"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  },
  "url": canonicalURL,
  "image": "https://darwinapolinario.xyz/og-image.jpg",
  "inLanguage": "en-US"
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://darwinapolinario.xyz"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://darwinapolinario.xyz/blog"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": canonicalURL
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} article={true} publishDate={post.data.date}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="mouse-glow"></div>

  <article class="mx-auto max-w-3xl px-6 py-12 lg:py-20">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-gruvbox-gray">
        <li><a href="/" class="hover:text-gruvbox-yellow transition-colors">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li><a href="/blog" class="hover:text-gruvbox-yellow transition-colors">Blog</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-gruvbox-fg3 truncate max-w-[200px]">{post.data.title}</li>
      </ol>
    </nav>

    <header class="mb-12">
      <time
        datetime={post.data.date.toISOString()}
        class="text-sm font-mono text-gruvbox-gray"
      >
        {formattedDate}
      </time>
      <h1 class="mt-3 text-3xl font-bold text-gruvbox-fg0 leading-tight sm:text-4xl lg:text-5xl">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg text-gruvbox-fg3 leading-relaxed">
        {post.data.description}
      </p>
    </header>

    <div class="prose-gruvbox">
      <Content />
    </div>

    <footer class="mt-16 border-t border-gruvbox-bg2 pt-8">
      <a
        href="/blog"
        class="group inline-flex items-center text-sm font-medium text-gruvbox-yellow hover:text-gruvbox-orange transition-colors"
      >
        <svg
          class="mr-2 h-4 w-4 transition-transform group-hover:-translate-x-1"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5"></path>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to all posts
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .mouse-glow {
    pointer-events: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 30;
    transition: opacity 0.3s;
    mix-blend-mode: screen;
  }

  html[data-theme='light'] .mouse-glow {
    mix-blend-mode: multiply;
    opacity: 1;
  }
</style>

<script>
  const mouseGlow = document.querySelector('.mouse-glow') as HTMLElement;
  const html = document.documentElement;

  const isTouchDevice = () => {
    return (
      'ontouchstart' in window ||
      navigator.maxTouchPoints > 0 ||
      window.matchMedia('(pointer: coarse)').matches
    );
  };

  if (!isTouchDevice()) {
    document.addEventListener('mousemove', (e) => {
      if (!mouseGlow) return;
      const isLightMode = html.getAttribute('data-theme') === 'light';
      if (isLightMode) {
        mouseGlow.style.background = `radial-gradient(600px circle at ${e.clientX}px ${e.clientY}px, rgba(215, 153, 33, 0.25), rgba(215, 153, 33, 0.12) 40%, transparent 70%)`;
      } else {
        mouseGlow.style.background = `radial-gradient(800px circle at ${e.clientX}px ${e.clientY}px, rgba(250, 189, 47, 0.15), rgba(250, 189, 47, 0.05) 40%, transparent 80%)`;
      }
    });
  } else if (mouseGlow) {
    mouseGlow.style.display = 'none';
  }
</script>
